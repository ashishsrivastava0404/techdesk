# =============================================================================
# DATABASE CONFIGURATION (Currently Used)
# =============================================================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=promote
DB_SOCKET=/run/mysqld/mysqld.sock

# =============================================================================
# SERVER CONFIGURATION (Currently Used)
# =============================================================================
PORT=3001
NODE_ENV=development
