# =============================================================================
# Promote Platform - Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!
#
# QUICK START:
# 1. cp .env.example .env
# 2. Fill in your database credentials
# 3. Set REDIS_ENABLED=false if Redis is not installed
# 4. npm run dev
#
# VARIABLE STATUS LEGEND:
# ✅ = Currently used in source code
# 🔧 = Optional / Has fallback behavior

# =============================================================================
# 🗄️ DATABASE CONFIGURATION
# =============================================================================

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=promote
DB_SOCKET=/run/mysqld/mysqld.sock  # Alternative socket path (Linux/Mac)

# =============================================================================
# 🌐 SERVER CONFIGURATION
# =============================================================================

PORT=3001
NODE_ENV=development  # or 'production'

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000  # Comma-separated list

# Frontend URL (for email links, OAuth redirects)
FRONTEND_URL=http://localhost:5173

# =============================================================================
# 🔐 AUTHENTICATION & SECURITY
# =============================================================================

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-32-characters
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# Session Configuration
SESSION_SECRET=your-session-secret-change-in-production

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# =============================================================================
# 📧 EMAIL & NOTIFICATIONS
# =============================================================================

# SendGrid Email
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=Promote Platform

# =============================================================================
# 📱 SMS & COMMUNICATIONS
# =============================================================================

# Twilio SMS
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# =============================================================================
# 💳 PAYMENT PROCESSING
# =============================================================================

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_CURRENCY=USD

# Stripe Connect (For Tech Payouts)
STRIPE_PLATFORM_ACCOUNT_ID=acct_xxxxx  # Your Stripe Connect platform account

# Razorpay (India)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# PayPal
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox  # or 'live' for production

# Bank Integration (Plaid)
BANK_API_KEY=your-plaid-api-key
BANK_API_SECRET=your-plaid-api-secret
BANK_ACCOUNT_ID=your-plaid-account-id

# =============================================================================
# ☁️ CLOUD STORAGE
# =============================================================================

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=promote-uploads

# Cloudinary (Alternative to S3)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# =============================================================================
# 🔴 REDIS CONFIGURATION
# =============================================================================

# Set to 'false' to disable Redis and use in-memory fallback
REDIS_ENABLED=true

# Redis Connection
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Redis is used for:
# ✅ Rate limiting (distributed across instances)
# ✅ Session management
# ✅ API response caching
# ✅ Refresh token storage
# ✅ Password reset tokens
# ✅ OAuth state tokens
#
# When REDIS_ENABLED=false, the application automatically uses
# in-memory fallback storage (suitable for single-instance deployments)

# =============================================================================
# 🛡️ ERROR TRACKING & MONITORING
# =============================================================================

# Sentry Error Tracking (Optional - leave empty to disable)
SENTRY_DSN=

# =============================================================================
# 🚀 ENVIRONMENT-SPECIFIC SETTINGS
# =============================================================================

# Production Settings Example:
# NODE_ENV=production
# REDIS_ENABLED=true
# REDIS_HOST=redis.production.internal
# REDIS_PASSWORD=your-redis-password
# DB_HOST=mysql.production.internal
# CORS_ORIGINS=https://yourdomain.com
# FRONTEND_URL=https://yourdomain.com

# Development Settings Example:
# NODE_ENV=development
# REDIS_ENABLED=false  # Use in-memory fallback
# DB_HOST=localhost
